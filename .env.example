# Copy to .env.local and fill in. .env.local is git-ignored; never commit real secrets.
#
# DATABASE — two supported styles:
#
# (A) Vercel AWS Marketplace integration (recommended): it injects PGHOST, PGPORT,
#     PGUSER, PGDATABASE for you. You only add PGPASSWORD (set a master password
#     on the Aurora cluster in the AWS RDS console). Pull the rest with:
#         npx vercel env pull .env.local
PGHOST="your-cluster.cluster-xxxx.<region>.rds.amazonaws.com"
PGPORT="5432"
PGUSER="postgres"
PGDATABASE="postgres"
PGPASSWORD="the-master-password-you-set-in-rds"

# (B) Or a single connection string instead of the PG* vars above:
# DATABASE_URL="postgres://user:password@host:5432/postgres?sslmode=require"

# Read-only role for the NL->SQL engine (the security showpiece; optional in dev).
# Either set DATABASE_URL_RO, or PGUSER_RO + PGPASSWORD_RO (reuses PGHOST/PGPORT/PGDATABASE).
# DATABASE_URL_RO="postgres://pulse_readonly:password@host:5432/postgres?sslmode=require"
# PGUSER_RO="pulse_readonly"
# PGPASSWORD_RO="the-readonly-role-password"

# --- Anthropic ---
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override; defaults to claude-opus-4-8 for the planning step.
# PULSE_PLAN_MODEL="claude-opus-4-8"

# Set to 1 only for local Postgres without TLS.
# PGSSL_DISABLE="1"
