# Copy to .env.local and fill in. .env.local is git-ignored; never commit real secrets.
#
# DATABASE — three supported styles (the app auto-detects which):
#
# (A) Vercel AWS Aurora integration with IAM auth (DEFAULT — no password!):
#     The integration injects these. Pull them with `npx vercel env pull .env.local`.
#     The app mints short-lived RDS IAM tokens via the Vercel OIDC token; you add nothing.
PGHOST="your-cluster.cluster-xxxx.<region>.rds.amazonaws.com"
PGPORT="5432"
PGUSER="postgres"
PGDATABASE="postgres"
AWS_ROLE_ARN="arn:aws:iam::<acct>:role/Vercel/access-..."
AWS_RESOURCE_ARN="arn:aws:rds:<region>:<acct>:cluster:..."
# AWS_REGION="ap-south-1"           # optional; derived from the host/ARN if absent
VERCEL_OIDC_TOKEN="..."             # injected by `vercel env pull` / Vercel runtime

# (B) Or password auth: add PGPASSWORD (e.g. the value from Secrets Manager).
# PGPASSWORD="the-db-password"

# (C) Or a single connection string:
# DATABASE_URL="postgres://user:password@host:5432/postgres?sslmode=require"

# Read-only role for the NL->SQL engine (the security showpiece; optional in dev).
# Either set DATABASE_URL_RO, or PGUSER_RO + PGPASSWORD_RO (reuses PGHOST/PGPORT/PGDATABASE).
# DATABASE_URL_RO="postgres://pulse_readonly:password@host:5432/postgres?sslmode=require"
# PGUSER_RO="pulse_readonly"
# PGPASSWORD_RO="the-readonly-role-password"

# --- Anthropic ---
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override; defaults to claude-opus-4-8 for the planning step.
# PULSE_PLAN_MODEL="claude-opus-4-8"

# Set to 1 only for local Postgres without TLS.
# PGSSL_DISABLE="1"

# One-time DB provisioning via POST /api/admin/setup (used when the cluster is
# IAM-managed and unreachable locally). Set a long random value in Vercel, call
# the endpoint once, then DELETE this var. Leave unset to disable the endpoint.
# SETUP_SECRET="a-long-random-string"
