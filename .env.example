# --- Aurora PostgreSQL (provision via the Vercel AWS Marketplace) ---
# Read-write: app logic + the /api/act write path + migrations + seed.
DATABASE_URL="postgres://user:password@host:5432/pulse?sslmode=require"

# Read-only role for the NL->SQL engine (create pulse_readonly; see BUILD-GUIDE §10).
# In dev you may omit this — the read path falls back to DATABASE_URL with a warning.
DATABASE_URL_RO="postgres://pulse_readonly:password@host:5432/pulse?sslmode=require"

# --- Anthropic ---
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override; defaults to claude-opus-4-8 for the planning step.
# PULSE_PLAN_MODEL="claude-opus-4-8"

# Set to 1 only for local Postgres without TLS.
# PGSSL_DISABLE="1"
